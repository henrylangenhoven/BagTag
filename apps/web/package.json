{
  "name": "bag-tag-ui",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "api:fetch": "node scripts/fetch-openapi.mjs && prettier --write ../../openapi/bagtag-api.json",
    "api:generate": "ng-openapi-gen -c ng-openapi-gen.json && prettier --write \"src/app/generated/bagtag-api/**/*.ts\"",
    "api:sync": "npm run api:fetch && npm run api:generate",
    "prepare": "cd ../.. && apps/web/node_modules/.bin/husky .husky"
  },
  "private": true,
  "packageManager": "npm@11.11.1",
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  }
}
